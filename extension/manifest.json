{
  "manifest_version": 3,
  "name": "Brewery",
  "version": "1.0.0",
  "description": "Brew your files — 100% local, straight from the tap. Convert images, audio, video, and data without uploading a thing.",
  "author": "Damon Phoenix",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Brewery — Brew your files",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },


  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "downloads",
    "offscreen"
  ],

  "host_permissions": [],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "wasm/*.wasm",
        "wasm/*.js",
        "wasm/*.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
